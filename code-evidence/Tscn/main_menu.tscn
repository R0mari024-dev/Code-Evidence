[sub_resource type="CSharpScript" id="CSharpScript_lqidy"]
script/source = "using Godot;
using System;

public partial class MainMenu : Control
{
    private ColorRect _matrixBackground;

    public override void _Ready()
    {
        _matrixBackground = GetNode<ColorRect>(\"ColorRect\");
        
        // Пример изменения скорости через код
        var material = (ShaderMaterial)_matrixBackground.Material;
        material.SetShaderParameter(\"speed\", 1.5f);
    }

    private void _on_start_button_pressed()
    {
        // Можно плавно менять цвет при старте
        var material = (ShaderMaterial)_matrixBackground.Material;
        material.SetShaderParameter(\"text_color\", new Color(1, 0, 0)); // Сделать красным
    }
}
"

